{
  "name": "@dynobox/sdk",
  "version": "0.0.1",
  "description": "Dynobox SDK for authoring scenario configs",
  "keywords": [
    "agent",
    "testing",
    "llm",
    "evals",
    "sdk"
  ],
  "homepage": "https://dynobox.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dynobox/dynobox.git",
    "directory": "packages/sdk"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --splitting false --clean && tsc -p tsconfig.json --emitDeclarationOnly --declaration",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && vitest run"
  },
  "author": "dynobox (https://dynobox.dev)",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "zod": "^4.1.12"
  }
}
