{
  "name": "@dynobox/evaluators",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Dynobox assertion evaluators",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --splitting false --clean && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && vitest run"
  },
  "dependencies": {
    "@dynobox/sdk": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
