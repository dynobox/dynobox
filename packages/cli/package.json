{
  "name": "dynobox",
  "version": "0.0.3",
  "description": "Placeholder - Dynobox is under active development. Docs to come at https://dynobox.dev",
  "keywords": [
    "agent",
    "testing",
    "llm",
    "claude-code",
    "codex",
    "evals"
  ],
  "homepage": "https://dynobox.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dynobox/dynobox.git",
    "directory": "packages/cli"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --splitting false --clean && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && vitest run"
  },
  "author": "dynobox (https://dynobox.dev)",
  "bin": {
    "dynobox": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
