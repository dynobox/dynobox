{
  "name": "dynobox-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "dynobox monorepo — cross-harness testing for multi-step agent flows",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "npm run format && npm run lint",
    "format": "prettier --check \"**/*.{js,cjs,mjs,ts,cts,mts,tsx,jsx,json}\"",
    "format:write": "prettier --write \"**/*.{js,cjs,mjs,ts,cts,mts,tsx,jsx,json}\"",
    "lint": "eslint .",
    "lint:write": "eslint . --fix",
    "test": "pnpm -r test",
    "typecheck": "pnpm run build && pnpm -r typecheck",
    "write": "npm run format:write && npm run lint:write"
  },
  "devDependencies": {
    "@dynobox/sdk": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5",
    "zod": "^4.1.12"
  }
}
